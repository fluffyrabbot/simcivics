---
import ReaderArtifact from '../components/ReaderArtifact.astro';
import type {
  AttachedModelSummary,
  BriefingMap,
  CommonGroundClaim,
  ReaderDisagreement,
  ReaderEvidence,
  PolicyOption,
  Uncertainty,
} from '../lib/reader-types';

// ── Projection: prepared from the event log, not hand-authored ──────────────
// In the real system this is generated by ExportArtifact(liveMapRef, format).
// Here it is seeded from the same Issue/Position/Crux data as the DialecticSession workbench.

const briefingMap: BriefingMap = {
  title: 'Midtown zoning live map, exported for outside readers',
  lastUpdatedAt: '2026-06-15T12:00:00Z',
  synthesis:
    'The live map has not resolved the zoning decision. It has narrowed the dispute to three obtainable evidence/model gaps and one irreducible value tradeoff. The strongest near-term synthesis is a phased upzone tied to school-capacity proof, a joint induced-VMT run, impact-fee reform, and explicit canopy/design standards.',
  nodes: [
    {
      id: 'synthesis_current_briefing',
      kind: 'synthesis',
      label: 'Current synthesis candidate',
      status: 'not adopted',
      summary:
        'Proceed only as far as the evidence supports: allow limited near-term production while making later density contingent on school-seat planning, traffic-model publication, and fiscal follow-on data.',
    },
    {
      id: 'pos_pro_upzone',
      kind: 'position',
      label: 'Pro-upzone position',
      status: 'v2',
      summary:
        'Housing demand is urgent; added supply near BRT can be absorbed if design rules, impact-fee reform, and infrastructure planning move with the upzone.',
    },
    {
      id: 'pos_concerned',
      kind: 'position',
      label: 'Concerned position',
      status: 'v3',
      summary:
        'The upzone should not outrun school capacity, road impacts, fiscal risk, or the real value current residents place on neighborhood character and canopy.',
    },
    {
      id: 'crux_school_capacity',
      kind: 'crux',
      label: 'School capacity',
      status: 'open factual crux',
      summary:
        'Both sides agree this is load-bearing and resolvable by a district enrollment projection through 2031 with upzone scenarios.',
    },
    {
      id: 'crux_induced_traffic',
      kind: 'crux',
      label: 'Induced VMT',
      status: 'open model crux',
      summary:
        'Both sides accept the city ABM but disagree on whether the defensible induced-VMT multiplier is 1.12 or 1.25+.',
    },
    {
      id: 'crux_fiscal_net',
      kind: 'crux',
      label: 'Net fiscal impact',
      status: 'partially addressed model crux',
      summary:
        'The sign of the 10-year per-unit fiscal impact turns on commercial follow-on absorption and school capital assumptions.',
    },
    {
      id: 'crux_character_canopy',
      kind: 'crux',
      label: 'Character and tree canopy',
      status: 'open value crux',
      summary:
        'The parties now agree this is a value weighting problem, not an evidence gap that better studies can dissolve.',
    },
    {
      id: 'sim_pro_upzone_traffic',
      kind: 'model',
      label: 'Pro-upzone traffic model v1.2',
      status: 'attached run',
      summary:
        'ABM subset run using 2,200 added units and a 1.12 induced-VMT multiplier; currently reports peak arterial volume +6.4%.',
    },
    {
      id: 'sim_concerned_fiscal',
      kind: 'model',
      label: 'Concerned fiscal impact model',
      status: 'attached run',
      summary:
        '10-year NPV per unit using city fiscal model, school capital schedule, and no commercial follow-on assumption; currently reports -$4,200 median per unit.',
    },
  ],
  edges: [
    { from: 'pos_pro_upzone', to: 'crux_school_capacity', label: 'accepts as load-bearing' },
    { from: 'pos_concerned', to: 'crux_school_capacity', label: 'requires before full upzone' },
    { from: 'sim_pro_upzone_traffic', to: 'crux_induced_traffic', label: 'models lower multiplier' },
    { from: 'sim_concerned_fiscal', to: 'crux_fiscal_net', label: 'models current fee risk' },
    { from: 'crux_character_canopy', to: 'synthesis_current_briefing', label: 'sets irreducible tradeoff' },
    { from: 'synthesis_current_briefing', to: 'pos_pro_upzone', label: 'preserves some supply' },
    { from: 'synthesis_current_briefing', to: 'pos_concerned', label: 'adds evidence gates' },
  ],
};

const commonGroundClaims: CommonGroundClaim[] = [
  {
    text: 'Housing demand in Midtown is real and growing; the status quo undersupplies relative to household formation.',
    breadth: 'across all positions',
  },
  {
    text: 'Infrastructure capacity — schools, water pressure, and arterial traffic — is a genuine constraint that must be honestly quantified in any upzone proposal.',
    breadth: 'across all positions',
  },
  {
    text: "The city's current impact fee schedule does not fully capture the marginal cost of new residents and should be revisited regardless of the zoning outcome.",
    breadth: 'across all positions',
  },
  {
    text: 'School capacity in this attendance area is load-bearing: both sides agree it is a decisive factual question, not a rhetorical one.',
    breadth: 'across all positions',
  },
];

const disagreements: ReaderDisagreement[] = [
  {
    name: 'Elementary and middle school capacity',
    type: 'factual',
    status: 'open',
    description:
      'Whether local elementary and middle schools can absorb 400–700 additional students without portable classrooms or attendance-boundary changes within 5 years of the upzone taking effect.',
    cases: [
      {
        side: 'Pro-upzone',
        coreArgument:
          'Current BRT and water/sewer headroom offset most infrastructure strain. School capacity is a real crux — accepted as such — but is resolvable: the district capital plan should be updated to reflect projected enrollment, which is an ask that can be made regardless of zoning outcome. The upzone should not be held hostage to inaction on the school plan.',
        steelmanWrittenBy: 'Concerned',
        steelmanText:
          'New housing will eventually pay for itself through increased property tax base and the BRT will absorb most new trips; design standards plus tree replacement requirements can protect neighborhood character.',
        steelmanEndorsed: false,
      },
      {
        side: 'Concerned',
        coreArgument:
          'The school district capital plan has no new seats funded in this attendance area for 6+ years. Adding 400–700 students without that plan being revised means portable classrooms at minimum and boundary disruptions that disproportionately affect existing lower-income families. The upzone should be contingent on a funded capacity commitment, not post-hoc mitigation.',
        steelmanWrittenBy: 'Pro-upzone',
        steelmanText:
          'Even with new units, infrastructure — especially schools and water pressure at peak — will be strained beyond capacity before any mitigation is built; the traffic model underestimates induced demand from new households.',
        steelmanEndorsed: true,
      },
    ],
    cruxResolutionPath:
      'A formal school district enrollment projection through 2031, modeled with and without the upzone, is obtainable from the district planning office. Both sides have agreed this data exists. Its publication would either resolve the factual question or clarify the gap that must be closed before the upzone proceeds.',
  },
  {
    name: 'Magnitude of induced vehicle miles traveled',
    type: 'model',
    status: 'open',
    description:
      "Whether the city activity-based model (ABM), run with updated induced-demand parameters, shows greater than 10% peak-hour volume degradation on the two main north-south arterials. The 10% threshold is the city's own significance criterion.",
    cases: [
      {
        side: 'Pro-upzone',
        coreArgument:
          'Our ABM run (v1.2) uses an induced-VMT multiplier of 1.12, which is consistent with recent local data. At 2,200 added units and that multiplier, peak arterial volume rises 6.4% — well below the 10% threshold. The new BRT reduces car trip generation per household compared to the regional average.',
        steelmanWrittenBy: 'Concerned',
        steelmanText:
          'The regional average induced-VMT multiplier understates the local case because east-west transit connections are weak; most new residents will drive for the bulk of trip purposes. A 1.25+ multiplier is more defensible, which would push arterial impact above 10%.',
        steelmanEndorsed: false,
      },
      {
        side: 'Concerned',
        coreArgument:
          'The pro-upzone model uses an induced-VMT multiplier that is too low for this location. Limited east-west transit means new households drive at above-average rates. At 1.25+, the same ABM produces degradation that crosses the 10% significance threshold. The disagreement is not about the model — both sides accept the city ABM — it is about which multiplier is defensible.',
        steelmanWrittenBy: 'Pro-upzone',
        steelmanText:
          'Even with new units, infrastructure will be strained beyond capacity before any mitigation is built; the traffic model underestimates induced demand from new households.',
        steelmanEndorsed: true,
      },
    ],
    modelResults: [
      {
        side: 'Pro-upzone',
        keyAssumption: 'Induced-VMT multiplier: 1.12 (local BRT effect included)',
        result: 'Peak arterial volume +6.4%',
        range: '+3.1% to +9.8% (5th–95th percentile)',
      },
      {
        side: 'Concerned',
        keyAssumption: 'Induced-VMT multiplier: 1.25 (limited east-west transit)',
        result: 'Peak arterial volume estimated +11–14%',
        range: 'Model run pending; based on parametric sensitivity of pro-upzone ABM',
      },
    ],
    cruxResolutionPath:
      'Both sides have agreed in writing to commission a joint city ABM run using the higher induced-demand parameters (1.25) and publish the resulting delta. This run has not yet been commissioned. Until it is, this crux is unresolved on the evidence, not on the model.',
  },
  {
    name: 'Net fiscal impact per new unit',
    type: 'model',
    status: 'partially_addressed',
    description:
      'Whether the net present fiscal impact per new unit over 10 years — including direct impact fees, property tax revenue, and the full marginal cost of city services (including schools) — is positive or negative. The disagreement hinges on whether commercial follow-on development materializes.',
    cases: [
      {
        side: 'Pro-upzone',
        coreArgument:
          'The fiscal concern is real but overstated because it ignores commercial follow-on development: every prior high-density upzone in comparable submarkets has attracted retail and office conversion within 4 years, substantially improving the per-unit tax base. The fiscal model should be run with and without follow-on assumptions and the range published.',
        steelmanWrittenBy: 'Concerned',
        steelmanText:
          'New housing will eventually pay for itself through increased property tax base; the BRT will absorb most new trips.',
        steelmanEndorsed: false,
      },
      {
        side: 'Concerned',
        coreArgument:
          "The city's fiscal impact model, applied to this upzone, produces a median net fiscal impact of -$4,200 per unit over 10 years when school capital costs are included. The tax-base argument assumes commercial follow-on that did not materialize in the 2018 or 2021 upzones in comparable areas. Until the absorption data from those upzones is published, the follow-on assumption cannot be taken on faith.",
        steelmanWrittenBy: 'Pro-upzone',
        steelmanText:
          'Even with new units, the marginal infrastructure cost per unit exceeds the marginal revenue under current impact fee schedules; net fiscal impact turns negative above roughly 900 added units without fee reform.',
        steelmanEndorsed: true,
      },
    ],
    modelResults: [
      {
        side: 'Concerned (city fiscal model)',
        keyAssumption: 'No commercial follow-on; school capital cost included at $48k/pupil',
        result: 'Median net fiscal: −$4,200 per unit over 10 years',
        range: '−$8,400 to −$1,100 depending on school absorption rate',
      },
      {
        side: 'Pro-upzone (with follow-on)',
        keyAssumption: 'Commercial follow-on consistent with 2018 state-average experience',
        result: 'Estimated net fiscal: +$3,800 to +$8,400 per unit over 10 years',
        range: 'Not yet formally modeled; range based on comparable upzone data',
      },
    ],
    cruxResolutionPath:
      "The city planning department holds absorption data from the 2018 and 2021 upzones. Both sides agree that releasing this data — actual commercial follow-on rates, not projections — would substantially narrow the range of the fiscal model. This is an information problem, not a modeling dispute. The data request has been made; publication is pending.",
  },
  {
    name: 'Character and tree-canopy loss',
    type: 'value',
    status: 'open',
    description:
      "Whether the loss of neighborhood character and tree canopy from a 2-story upzone — even with design standards — constitutes an acceptable cost. This is not a factual question about whether losses will occur (both sides agree they will), but about how much weight those losses deserve.",
    cases: [
      {
        side: 'Pro-upzone',
        coreArgument:
          'Design standards and tree-replacement requirements can materially mitigate character and canopy loss. The scale of housing need — real people priced out of the city — morally outweighs the aesthetic preferences of existing homeowners. Density done well can preserve and even enhance street vitality.',
        steelmanWrittenBy: 'Concerned',
        steelmanText:
          'Design standards plus tree replacement requirements can protect neighborhood character; density done well can preserve street vitality.',
        steelmanEndorsed: false,
      },
      {
        side: 'Concerned',
        coreArgument:
          'Character and canopy loss from 2-story upzones are not fully mitigable by design standards, and will be experienced as a quality-of-life decline by long-term residents — disproportionately those without the option to move. The interests of current residents in the place they chose and invested in are legitimate, not merely NIMBY preference.',
        steelmanWrittenBy: 'Pro-upzone',
        steelmanText:
          'Character and canopy losses from 2-story upzones are not fully mitigable by design standards and will be perceived as a quality-of-life decline by long-term residents.',
        steelmanEndorsed: true,
      },
    ],
    valueTension:
      "Both sides are defending legitimate goods: housing access for people currently excluded, and the quality of place for people currently invested in it. These are not symmetrically comparable on any single scale. The policy question is how much of one to trade for the other, and who bears the cost of the choice. Design standards and phasing can reduce the tradeoff's sharpness but cannot eliminate it.",
    cruxResolutionPath:
      'This crux does not resolve on evidence — it requires a value weighting. The question for the policy process is: what design standards and replacement requirements are actually binding (not just on paper), and which residents bear the cost of each scenario?',
  },
];

const evidenceItems: ReaderEvidence[] = [
  {
    citation: 'Local parcel-level housing supply study, 2024 (City Planning Dept.)',
    quality: 'primary_admin_data',
    bearsOn: ['Pro-upzone traffic model (elasticity estimate)', 'Fiscal model base case'],
    excerpt:
      'Price elasticity of housing supply in the submarket estimated at −0.25 to −0.40 using parcel-level data 2018–2023.',
    limitation:
      'Covers 2018–2023 only; does not account for post-2023 interest-rate environment or changed permitting timelines.',
  },
  {
    citation: 'City fiscal impact model, applied to comparable upzone, 2025 (City Finance Office)',
    quality: 'high_quality_gov_report',
    bearsOn: ['Net fiscal impact crux'],
    excerpt:
      'Median net fiscal impact per unit: −$4,200 over 10 years under baseline assumptions including school capital at $48,000 per added pupil.',
    limitation:
      'Does not model commercial follow-on scenarios. School capital cost estimate uses district-reported figures that may not reflect updated construction costs.',
  },
  {
    citation: 'Pro-upzone traffic model v1.2 (ABM run, 2026-06-03)',
    quality: 'other',
    bearsOn: ['Induced-VMT crux'],
    excerpt:
      'Peak arterial volume +6.4% at 2,200 added units and induced-VMT multiplier of 1.12.',
    limitation:
      'Uses pro-upzone position\'s stated multiplier (1.12). Concerned position disputes this parameter. A jointly-agreed ABM run has not yet been commissioned.',
  },
  {
    citation: 'School district capital plan, 2024–2030 (School District Planning Office)',
    quality: 'primary_admin_data',
    bearsOn: ['School capacity crux', 'Fiscal model (school capital line)'],
    limitation:
      'No new seats are currently funded in this attendance area through 2030. The plan does not include upzone enrollment scenarios. The projection request has been submitted but is pending.',
  },
];

const modelSummaries: AttachedModelSummary[] = [
  {
    id: 'sim_pro_upzone_traffic',
    label: 'Pro-upzone traffic model v1.2',
    attachedTo: 'Pro-upzone position v2',
    keyAssumptions: [
      '2,200 added units in the station-core upzone scenario.',
      'Induced-VMT multiplier of 1.12 after accounting for the new BRT line.',
      'Current peak arterial spare capacity remains within the city ABM baseline.',
    ],
    resultSummary:
      'Peak arterial volume rises 6.4%, with a 5th-95th percentile range of +3.1% to +9.8%, below the city significance threshold.',
    limitation:
      'The concerned position disputes the 1.12 multiplier. The model is useful as a transparent assumption bundle, not as a settled finding until the joint 1.25+ run is completed.',
  },
  {
    id: 'sim_concerned_fiscal',
    label: 'Concerned fiscal impact model',
    attachedTo: 'Concerned position v3',
    keyAssumptions: [
      '1,800 added units under current impact fees.',
      'School capital cost included at $48,000 per added pupil.',
      'No commercial follow-on development counted in the base case.',
    ],
    resultSummary:
      'Median net fiscal impact is -$4,200 per unit over 10 years, with a range from -$8,400 to -$1,100 depending on school absorption.',
    limitation:
      'The pro-upzone position disputes the no-follow-on assumption. City absorption data from the 2018 and 2021 upzones is needed before treating the fiscal sign as resolved.',
  },
];

const policyOptions: PolicyOption[] = [
  {
    name: 'Full 2-story upzone with reformed impact fees',
    assumes: [
      'Impact fee schedule is revised upward before entitlements are issued.',
      'Tree-replacement and design standards are binding, not advisory.',
      'School district submits revised enrollment plan within 18 months.',
    ],
    helps: [
      'Households currently priced out of Midtown.',
      'Builders with near-term pipeline.',
      'City fiscal position if commercial follow-on materializes.',
    ],
    costs: [
      'Existing residents facing character and canopy change.',
      'Families in attendance area if school plan is delayed.',
    ],
    risks: [
      'School capacity shortfall if district plan is not delivered on schedule.',
      'Impact fee reform may slow entitlements in short term.',
    ],
    monitor: [
      'School enrollment projections annually against plan.',
      'Actual vs. projected induced VMT at 2 and 5 years.',
      'Commercial follow-on absorption at 3 years.',
    ],
  },
  {
    name: 'Phased upzone contingent on school capital commitment',
    assumes: [
      'District provides a funded capital commitment for 400+ seats before Phase 2 takes effect.',
      'Phase 1 (up to ~900 units) proceeds without the commitment.',
    ],
    helps: [
      'Protects families in attendance area in near term.',
      'Creates accountability mechanism for school capacity.',
    ],
    costs: [
      'Slows housing delivery; fewer units in years 1–3.',
      'Builders face investment uncertainty during phased trigger.',
    ],
    risks: [
      'District commitment may be slow or insufficient; Phase 2 delayed indefinitely.',
    ],
    monitor: [
      'District capital plan revisions.',
      'Enrollment against Phase 1 projections.',
    ],
  },
  {
    name: 'No upzone pending infrastructure studies',
    assumes: [
      'Joint ABM run and district enrollment projection are completed first.',
      'Status quo zoning is acceptable for 18–24 months.',
    ],
    helps: [
      'Clarifies factual disputes before commitment.',
      'Reduces risk of a decision that later proves mistaken on the evidence.',
    ],
    costs: [
      'Households currently priced out continue to be excluded.',
      'Pipeline projects in limbo during study period.',
    ],
    risks: [
      'Studies may be delayed or inconclusive; moratorium extends further.',
    ],
    monitor: [
      'Study commission timelines.',
      'Housing permit rates in adjacent areas during moratorium.',
    ],
  },
];

const uncertainties: Uncertainty[] = [
  {
    text: 'Whether local elementary and middle schools can absorb 400–700 additional students without new seats or boundary changes within 5 years.',
    wouldChangeIf:
      'The school district publishes a formal enrollment projection through 2031 that includes upzone scenarios. This request has been submitted.',
  },
  {
    text: 'The magnitude of induced vehicle miles traveled from new households — specifically whether the correct ABM multiplier is 1.12 (pro-upzone) or 1.25+ (concerned), and whether the result crosses the 10% significance threshold.',
    wouldChangeIf:
      'Both sides have agreed to commission a joint ABM run using the higher multiplier. Until that run is completed and published, this is unresolved on the evidence.',
  },
  {
    text: "Whether commercial follow-on development materializes in upzoned areas, which is the pivotal variable in the net fiscal impact model. The 2018 and 2021 upzone areas' absorption data is held by the city but has not been released.",
    wouldChangeIf:
      'City planning releases the 5-year commercial absorption data from the 2018 and 2021 upzones. This is an administrative request that does not require new analysis.',
  },
];

const changesSince = {
  sinceDate: '2026-06-02',
  entries: [
    {
      text: 'Pro-upzone position (v2) accepted school capacity as a load-bearing crux and committed to running the city ABM with higher induced-demand parameters.',
    },
    {
      text: 'Concerned position (v3) updated the fiscal impact model to include commercial follow-on sensitivity ranges and submitted the data request to city planning.',
    },
    {
      text: "Pro-upzone's steelman of the concerned position was endorsed as fair by concerned participants — the representation of their argument was confirmed as accurate.",
    },
    {
      text: 'Character/canopy crux reclassified from model to value after both sides agreed the disagreement is not resolvable by evidence.',
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Midtown Zoning — simcivics reader artifact</title>
    <style>
      :root {
        --bg: #0b0b0c;
        --fg: #e6e6e8;
        --muted: #8a8a90;
        --border: #252528;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
      }
      .page-container {
        max-width: 820px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 4rem;
      }
      .page-nav {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1rem;
        margin-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
        font-size: 0.83rem;
        color: var(--muted);
      }
      .page-nav a {
        color: var(--muted);
        text-decoration: none;
      }
      .page-nav a:hover { color: var(--fg); }
      .page-nav .nav-sep { color: var(--border); }
      .page-nav .nav-current { color: var(--fg); }
    </style>
  </head>
  <body>
    <div class="page-container">
      <nav class="page-nav" aria-label="Breadcrumb">
        <a href="/">simcivics</a>
        <span class="nav-sep">›</span>
        <span class="nav-current">Reader artifact — Midtown zoning</span>
        <span style="margin-left:auto">
          <a href="/">← Contributor workbench</a>
        </span>
      </nav>

      <ReaderArtifact
        issueTitle="How should Midtown zoning change to increase housing production while managing infrastructure strain?"
        issueScope="municipal"
        issueDomain="housing · zoning"
        valueConflicts={[
          'growth vs. neighborhood character',
          'housing access vs. existing resident protections',
          'short-term supply vs. long-term infrastructure capacity',
        ]}
        status="active"
        artifactVersion={3}
        artifactDate="2026-06-15"
        exportSlug="midtown-zoning-v3"
        briefingMap={briefingMap}
        commonGroundClaims={commonGroundClaims}
        disputedSummary={[
          { label: 'Whether local schools can absorb 400–700 additional students in 5 years', type: 'factual' },
          { label: 'Magnitude of induced vehicle miles traveled from new households', type: 'model' },
          { label: 'Net fiscal impact per new unit over 10 years', type: 'model' },
          { label: 'Acceptability of character and tree-canopy loss', type: 'value' },
        ]}
        bottomLine="The two factual disputes (school capacity, induced VMT) are resolvable with data that is obtainable but not yet published — a district enrollment projection and a joint ABM run. The fiscal dispute turns on commercial follow-on absorption data held by the city. Until these three datasets are released, any decision commits to one set of assumptions on thin evidence. A short moratorium to obtain these datasets is low-cost relative to the risk of getting the factual disputes wrong. The value dispute (character/canopy) is irreducible and will not be resolved by further study — it requires a policy choice."
        disagreements={disagreements}
        modelSummaries={modelSummaries}
        evidenceItems={evidenceItems}
        policyOptions={policyOptions}
        uncertainties={uncertainties}
        changesSince={changesSince}
        aiDisclosure="AI assistance was used to draft connective prose in this artifact and to flag potential steelman gaps. AI made no content decisions: it did not determine what counts as agreed, resolve factual disputes, or select policy positions. Every substantive claim is traceable to a participant contribution in the event log."
        gardenersNote="This artifact is maintained by gardeners drawn from across opinion clusters. Gardeners ratify fairness ratings before promotion to the public artifact; no single-cluster majority can publish a synthesis. Cross-cluster fairness review is the gate, not editorial discretion."
      />
    </div>
  </body>
</html>
