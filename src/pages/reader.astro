---
import ReaderArtifact from '../components/ReaderArtifact.astro';
import { projectReaderArtifact } from '../lib/reader-projection';
import { midtownZoningWorkspace } from '../lib/seeded-issue-workspace';

const readerArtifact = projectReaderArtifact(midtownZoningWorkspace);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{midtownZoningWorkspace.shortTitle} - simcivics reader artifact</title>
    <style>
      :root {
        --bg: #0b0b0c;
        --fg: #e6e6e8;
        --muted: #8a8a90;
        --border: #252528;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
      }
      .page-container {
        max-width: 820px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 4rem;
      }
      .page-nav {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1rem;
        margin-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
        font-size: 0.83rem;
        color: var(--muted);
      }
      .page-nav a {
        color: var(--muted);
        text-decoration: none;
      }
      .page-nav a:hover { color: var(--fg); }
      .page-nav .nav-sep { color: var(--border); }
      .page-nav .nav-current { color: var(--fg); }
    </style>
  </head>
  <body>
    <div class="page-container">
      <nav class="page-nav" aria-label="Breadcrumb">
        <a href="/">simcivics</a>
        <span class="nav-sep">/</span>
        <span class="nav-current">Reader artifact - {midtownZoningWorkspace.shortTitle}</span>
        <span style="margin-left:auto">
          <a href="/">Contributor workbench</a>
        </span>
      </nav>

      <ReaderArtifact {...readerArtifact} />
    </div>
  </body>
</html>
