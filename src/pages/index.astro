---
import DialecticSessionWorkbench from '../components/DialecticSessionWorkbench.astro';
import { midtownZoningWorkspace } from '../lib/seeded-issue-workspace';

const {
  cruxes: midtownCruxes,
  dialecticSession: midtownDialecticSession,
  evidence: midtownEvidence,
  issue: midtownIssue,
  positions: midtownPositions,
} = midtownZoningWorkspace;

const artifacts = midtownDialecticSession.phaseArtifacts;
const synthesis = artifacts.synthesisAttempt;

const prioritizedCruxes = [...artifacts.cruxPriorities].sort((a, b) => a.priority - b.priority);
const openCruxes = midtownCruxes.filter((crux) => crux.status === 'open' || crux.status === 'partially_addressed');
const nextWork = artifacts.focusedWork
  .filter((work) => work.status !== 'complete')
  .sort((a, b) => {
    const order = { in_progress: 0, not_started: 1, blocked: 2, complete: 3 };
    return order[a.status] - order[b.status];
  });
const completedWork = artifacts.focusedWork.filter((work) => work.status === 'complete');
const acceptedSteelmans = artifacts.crossSteelmans.filter((steelman) => steelman.targetResponse === 'accepted').length;
const needsRevisionSteelmans = artifacts.crossSteelmans.filter((steelman) => steelman.targetResponse === 'needs_revision').length;

function positionName(positionId: string): string {
  return midtownPositions.find((position) => position.id === positionId)?.authorId ?? positionId;
}

function cruxFor(cruxId: string) {
  return midtownCruxes.find((crux) => crux.id === cruxId);
}

function evidenceLabel(evidenceId: string): string {
  return midtownEvidence.find((evidence) => evidence.id === evidenceId)?.citation ?? evidenceId;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>simcivics • dialectic substrate</title>
    <style>
      :root {
        --bg: #0d1014;
        --panel: #141820;
        --panel-strong: #18202b;
        --fg: #f1f3f5;
        --muted: #a8b0bb;
        --quiet: #7e8996;
        --accent: #4f8df7;
        --green: #6fd28f;
        --amber: #d7b75b;
        --red: #ef7d8a;
        --border: #2a313b;
      }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
      }
      .container {
        max-width: 1240px;
        margin: 0 auto;
        padding: 1.25rem;
      }
      header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: start;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
      }
      h1 { font-size: clamp(1.6rem, 2.5vw, 2.35rem); margin: 0.25rem 0 0.35rem; line-height: 1.1; max-width: 950px; }
      h2 { margin: 0 0 0.75rem; font-size: 1rem; letter-spacing: 0.02em; text-transform: uppercase; color: #d8dde5; }
      h3 { margin: 0; line-height: 1.25; }
      p { margin: 0; }
      a { color: inherit; }
      .eyebrow { margin: 0; color: var(--quiet); font-size: 0.76rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; }
      .tagline { color: var(--muted); font-size: 1rem; max-width: 880px; }
      .top-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: end; }
      .button-link {
        display: inline-flex;
        min-height: 2.35rem;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--panel);
        padding: 0 0.8rem;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.88rem;
      }
      .button-link.primary { border-color: #315fae; background: #12213a; color: #cfe0ff; }
      .workspace-status {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 0.65rem;
        margin-bottom: 1rem;
      }
      .stat, .panel, .position, .crux, .work, .evidence {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.95rem;
      }
      .stat strong { display: block; font-size: 1.35rem; line-height: 1; margin-bottom: 0.25rem; }
      .stat span, .meta { font-size: 0.84rem; color: var(--muted); }
      .main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.8fr);
        gap: 1rem;
        align-items: start;
        margin-bottom: 1rem;
      }
      .stack { display: grid; gap: 0.75rem; }
      .panel-header { display: flex; justify-content: space-between; gap: 0.75rem; align-items: start; margin-bottom: 0.75rem; }
      .panel-header p { color: var(--muted); font-size: 0.9rem; }
      .issue-brief { display: grid; gap: 0.75rem; }
      .chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .chip {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        border: 1px solid #35404d;
        border-radius: 999px;
        background: #111720;
        color: #d5dce5;
        padding: 0.2rem 0.55rem;
        font-size: 0.75rem;
        font-weight: 750;
        text-transform: uppercase;
      }
      .chip.open { border-color: #5b4f2b; color: #f0d783; background: #211d10; }
      .chip.partial { border-color: #2b4f72; color: #a9ccff; background: #101b2b; }
      .chip.done { border-color: #2a5c3d; color: #9df1b9; background: #102018; }
      .summary { color: #dce1e7; font-size: 1.02rem; }
      .value-conflicts { display: grid; gap: 0.35rem; color: var(--muted); font-size: 0.9rem; }
      .value-conflicts li { margin: 0; }
      .crux-list, .work-list, .position-grid, .evidence-grid { display: grid; gap: 0.65rem; }
      .crux { display: grid; gap: 0.45rem; border-left: 3px solid var(--amber); }
      .crux.top { border-left-color: var(--green); }
      .crux-head, .work-head, .position-head, .evidence-head { display: flex; justify-content: space-between; gap: 0.75rem; align-items: start; }
      .crux-title { font-weight: 750; }
      .crux p, .work p, .position p, .evidence p { color: #d3d9e0; font-size: 0.92rem; }
      .crux small, .work small, .position small, .evidence small { color: var(--quiet); }
      .work { display: grid; gap: 0.5rem; border-left: 3px solid var(--accent); }
      .work.in_progress { border-left-color: var(--amber); }
      .work.complete { border-left-color: var(--green); }
      .work.blocked { border-left-color: var(--red); }
      .section-band { margin-top: 1rem; }
      .position-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .position { display: grid; gap: 0.75rem; }
      .claims { display: grid; gap: 0.5rem; }
      .claim {
        border-left: 3px solid var(--accent);
        padding-left: 0.65rem;
        color: #dce1e7;
        font-size: 0.9rem;
      }
      .evidence-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .evidence { background: #111820; }
      .artifact-link {
        display: block;
        padding: 0.95rem;
        background: #101a2a;
        border: 1px solid #2e5da9;
        border-left: 3px solid var(--accent);
        border-radius: 6px;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.15s, background 0.15s;
      }
      .artifact-link:hover { background: #122642; border-color: #75a6ff; }
      .artifact-chip {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.35rem;
      }
      .artifact-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--fg);
        margin-bottom: 0.35rem;
        line-height: 1.4;
      }
      .artifact-meta { font-size: 0.78rem; color: var(--muted); }
      .workbench-shell {
        margin-top: 1rem;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
      }
      footer {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        color: var(--quiet);
        font-size: 0.85rem;
      }
      @media (max-width: 960px) {
        header, .main-grid, .position-grid, .evidence-grid, .workspace-status { grid-template-columns: 1fr; }
        .top-actions { justify-content: start; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <div>
          <p class="eyebrow">{midtownZoningWorkspace.shortTitle} issue workspace</p>
          <h1>{midtownIssue.title}</h1>
          <p class="tagline">{midtownIssue.description}</p>
        </div>
        <nav class="top-actions" aria-label="Workspace actions">
          <a href="#workbench" class="button-link primary">Open contributor workbench</a>
          <a href="/reader" class="button-link">Reader artifact</a>
        </nav>
      </header>

      <section class="workspace-status" aria-label="Issue status">
        <div class="stat">
          <strong>{midtownIssue.status}</strong>
          <span>issue status</span>
        </div>
        <div class="stat">
          <strong>{midtownPositions.length}</strong>
          <span>seeded positions</span>
        </div>
        <div class="stat">
          <strong>{openCruxes.length}</strong>
          <span>live cruxes</span>
        </div>
        <div class="stat">
          <strong>{acceptedSteelmans}/{artifacts.crossSteelmans.length}</strong>
          <span>steelmans accepted</span>
        </div>
        <div class="stat">
          <strong>{nextWork.length}</strong>
          <span>next useful actions</span>
        </div>
      </section>

      <main>
        <section class="main-grid" aria-label="Live Midtown workspace">
          <div class="stack">
            <section class="panel issue-brief">
              <div class="panel-header">
                <div>
                  <p class="eyebrow">Issue summary</p>
                  <h2>Current decision frame</h2>
                </div>
                <div class="chips">
                  <span class="chip">{midtownIssue.scope}</span>
                  {midtownIssue.domainTags.map((tag) => <span class="chip">{tag}</span>)}
                </div>
              </div>
              <p class="summary">
                The workspace is testing whether Midtown can add meaningful station-area housing without
                outrunning schools, arterial capacity, fiscal commitments, or the character and canopy values
                named by current residents.
              </p>
              <ul class="value-conflicts">
                {midtownIssue.valueConflicts.map((conflict) => <li>{conflict}</li>)}
              </ul>
            </section>

            <section class="panel">
              <div class="panel-header">
                <div>
                  <p class="eyebrow">Current LiveMap</p>
                  <h2>What the map says now</h2>
                </div>
                <span class="chip partial">synthesis attempt</span>
              </div>
              {synthesis && (
                <div class="stack">
                  <p class="summary">{synthesis.policyMove}</p>
                  <div class="chips">
                    {synthesis.sharedCommitments.map((commitment) => <span class="chip done">{commitment}</span>)}
                  </div>
                </div>
              )}
            </section>

            <section class="panel">
              <div class="panel-header">
                <div>
                  <p class="eyebrow">Live cruxes</p>
                  <h2>Load-bearing disagreements</h2>
                </div>
                <span class="meta">{prioritizedCruxes.length} prioritized</span>
              </div>
              <div class="crux-list">
                {prioritizedCruxes.map((priority) => {
                  const crux = cruxFor(priority.cruxId);
                  return (
                    <article class={`crux ${priority.priority === 1 ? 'top' : ''}`}>
                      <div class="crux-head">
                        <span class="crux-title">#{priority.priority} {crux?.description ?? priority.cruxId}</span>
                        <span class={`chip ${crux?.status === 'partially_addressed' ? 'partial' : 'open'}`}>
                          {crux?.type ?? 'crux'} / {crux?.status.replace('_', ' ') ?? 'open'}
                        </span>
                      </div>
                      <p>{priority.whyLoadBearing}</p>
                      <small>Would move if: {priority.wouldMoveIf}</small>
                    </article>
                  );
                })}
              </div>
            </section>
          </div>

          <aside class="stack" aria-label="Next actions and reader artifact">
            <a href="/reader" class="artifact-link">
              <div class="artifact-chip">Preserved reader artifact</div>
              <div class="artifact-title">{midtownZoningWorkspace.shortTitle} live map, exported for outside readers</div>
              <div class="artifact-meta">Static briefing with map, cruxes, opposing positions, model summaries, and synthesis caveats.</div>
            </a>

            <section class="panel">
              <div class="panel-header">
                <div>
                  <p class="eyebrow">Next useful actions</p>
                  <h2>Do these before arguing more</h2>
                </div>
                <span class="chip open">{nextWork.length} open</span>
              </div>
              <div class="work-list">
                {nextWork.map((work) => {
                  const crux = cruxFor(work.cruxId);
                  return (
                    <article class={`work ${work.status}`}>
                      <div class="work-head">
                        <strong>{work.title}</strong>
                        <span class={`chip ${work.status === 'in_progress' ? 'open' : 'partial'}`}>{work.status.replace('_', ' ')}</span>
                      </div>
                      <p>{work.notes}</p>
                      <small>{work.kind.replace('_', ' ')} for {crux?.type ?? 'crux'} crux, owned by {work.ownerPositionId ? positionName(work.ownerPositionId) : 'session gardeners'}</small>
                    </article>
                  );
                })}
                {completedWork.map((work) => (
                  <article class="work complete">
                    <div class="work-head">
                      <strong>{work.title}</strong>
                      <span class="chip done">complete</span>
                    </div>
                    <p>{work.notes}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="panel">
              <div class="panel-header">
                <div>
                  <p class="eyebrow">Steelman state</p>
                  <h2>Cross-side charity signal</h2>
                </div>
                <span class="chip partial">{needsRevisionSteelmans} needs revision</span>
              </div>
              <div class="stack">
                {artifacts.crossSteelmans.map((steelman) => (
                  <article class="work">
                    <div class="work-head">
                      <strong>{positionName(steelman.fromPositionId)} -> {positionName(steelman.targetPositionId)}</strong>
                      <span class={`chip ${steelman.targetResponse === 'accepted' ? 'done' : 'partial'}`}>{steelman.targetResponse.replace('_', ' ')}</span>
                    </div>
                    <p>{steelman.targetNote}</p>
                  </article>
                ))}
              </div>
            </section>
          </aside>
        </section>

        <section class="section-band" aria-label="Seeded positions">
          <div class="panel-header">
            <div>
              <p class="eyebrow">Positions</p>
              <h2>Structured stances in the current issue map</h2>
            </div>
          </div>
          <div class="position-grid">
            {midtownPositions.map((position) => (
              <article class="position">
                <div class="position-head">
                  <div>
                    <h3>{position.authorId}</h3>
                    <p class="meta">Position v{position.version}, updated {new Date(position.updatedAt).toLocaleDateString('en-US')}</p>
                  </div>
                  <span class="chip">{position.cruxesIdentified.length} cruxes</span>
                </div>
                <div class="claims">
                  {position.coreClaims.map((claim) => (
                    <p class="claim"><strong>{claim.type}:</strong> {claim.text}</p>
                  ))}
                </div>
                <p>
                  Evidence attached: {position.evidenceRefs.map((ref) => evidenceLabel(ref.evidenceId)).join('; ') || 'none yet'}
                </p>
              </article>
            ))}
          </div>
        </section>

        <section class="section-band" aria-label="Evidence">
          <div class="panel-header">
            <div>
              <p class="eyebrow">Evidence shelf</p>
              <h2>Current materials attached to claims</h2>
            </div>
          </div>
          <div class="evidence-grid">
            {midtownEvidence.map((evidence) => (
              <article class="evidence">
                <div class="evidence-head">
                  <strong>{evidence.citation}</strong>
                  <span class="chip">{evidence.quality.replaceAll('_', ' ')}</span>
                </div>
                <p>{evidence.relevanceNotes}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="workbench" class="workbench-shell" aria-label="Contributor workbench">
          <div class="panel-header">
            <div>
              <p class="eyebrow">Contributor workbench</p>
              <h2>Run the DialecticSession</h2>
              <p>
                This is the main product surface: participants review structured positions, repair steelmans,
                mark cruxes, move evidence and model work, then decide whether the synthesis candidate should
                update the LiveMap.
              </p>
            </div>
          </div>
          <DialecticSessionWorkbench />
        </section>
      </main>

      <footer>
        Workspace projection from the seeded {midtownZoningWorkspace.shortTitle} issue data and DialecticSession artifacts. The outside-reader artifact remains available at <a href="/reader">/reader</a>.
      </footer>
    </div>
  </body>
</html>
